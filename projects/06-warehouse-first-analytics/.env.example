PROJECT_NAME=warehouse-first-analytics

# Google Cloud / BigQuery
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=US
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# dbt BigQuery profile target
DBT_PROFILE=stackoverflow_analytics
DBT_TARGET=bigquery

# Source dataset
SOURCE_BQ_PROJECT=bigquery-public-data
SOURCE_BQ_DATASET=stackoverflow

# Target dataset in your GCP project (dbt writes models here)
TARGET_BQ_DATASET=stackoverflow_analytics

# Cost control: year filter applied to staging models to limit scan volume
# Queries without this filter would scan the full posts table (~70 GB+)
STACKOVERFLOW_MIN_YEAR=2021
