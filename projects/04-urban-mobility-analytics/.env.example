# =========================
# Project identity
# =========================
PROJECT_NAME=urban-mobility-analytics
PROJECT_ENV=local
DATASET_SLUG=yellow_taxi

# =========================
# Official NYC TLC source
# =========================
SOURCE_PAGE_URL=https://www.nyc.gov/site/tlc/about/tlc-trip-record-data.page
SOURCE_DICTIONARY_URL=https://www.nyc.gov/assets/tlc/downloads/pdf/data_dictionary_trip_records_yellow.pdf
SOURCE_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data

# Default local review window
DEFAULT_START_MONTH=2024-01
DEFAULT_END_MONTH=2024-02

# =========================
# Runtime tuning
# =========================
REQUEST_TIMEOUT_SECONDS=120
DOWNLOAD_CHUNK_SIZE_BYTES=1048576

# =========================
# Local data paths
# =========================
BRONZE_RAW_DIR=data/bronze/raw
BRONZE_METADATA_DIR=data/bronze/metadata
BRONZE_STATE_DIR=data/bronze/state

SILVER_TABLES_DIR=data/silver/tables
SILVER_METADATA_DIR=data/silver/metadata
SILVER_STATE_DIR=data/silver/state

GOLD_TABLES_DIR=data/gold/tables
GOLD_METADATA_DIR=data/gold/metadata
GOLD_STATE_DIR=data/gold/state
