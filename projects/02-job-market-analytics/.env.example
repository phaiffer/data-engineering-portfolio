# =========================
# Project identity
# =========================
PROJECT_NAME=job-market-analytics
PROJECT_ENV=local

# =========================
# Kaggle / source
# =========================
KAGGLE_DATASET_HANDLE=uom190346a/ai-powered-job-market-insights

# =========================
# Local data paths
# =========================
BRONZE_RAW_DIR=projects/02-job-market-analytics/data/bronze/raw
BRONZE_METADATA_DIR=projects/02-job-market-analytics/data/bronze/metadata
SILVER_DIR=projects/02-job-market-analytics/data/silver
GOLD_DIR=projects/02-job-market-analytics/data/gold

# Main dataset artifact names
SILVER_DATASET_FILENAME=ai_job_market_insights_silver.csv
SILVER_METADATA_FILENAME=ai_job_market_insights_silver_metadata.json
GOLD_METADATA_FILENAME=gold_metadata.json

# =========================
# PostgreSQL
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=job_market_analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# Target schemas for the upcoming PostgreSQL path
POSTGRES_ANALYTICS_SCHEMA=analytics
POSTGRES_MARTS_SCHEMA=marts

# Main loaded Silver table
POSTGRES_SILVER_TABLE=job_market_insights_silver

# =========================
# DBT
# =========================
DBT_PROJECT_DIR=projects/02-job-market-analytics/dbt
DBT_PROFILES_DIR=projects/02-job-market-analytics/dbt
DBT_TARGET=duckdb

# DuckDB path for the current local DBT path
DUCKDB_PATH=projects/02-job-market-analytics/data/job_market_analytics.duckdb

# Silver source path for DBT local modeling
DBT_SILVER_DATASET_PATH=../data/silver/ai_job_market_insights_silver.csv

# =========================
# Logging / runtime
# =========================
LOG_LEVEL=INFO
JOB_MARKET_POSTGRES_HOST=localhost
JOB_MARKET_POSTGRES_PORT=5432
JOB_MARKET_POSTGRES_DB=job_market_analytics
JOB_MARKET_POSTGRES_USER=postgres
JOB_MARKET_POSTGRES_PASSWORD=postgres
JOB_MARKET_DBT_SCHEMA=marts
