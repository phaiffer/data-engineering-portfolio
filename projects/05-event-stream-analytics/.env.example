PROJECT_NAME=event-stream-analytics
SOURCE_STREAM_URL=https://stream.wikimedia.org/v2/stream/recentchange
SOURCE_DOCS_URL=https://wikitech.wikimedia.org/wiki/EventStreams
SOURCE_SCHEMA_URL=https://schema.wikimedia.org/repositories/primary/jsonschema/mediawiki/recentchange/latest.yaml
SOURCE_STREAM_NAME=recentchange
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092
RAW_TOPIC_NAME=wikimedia.recentchange.raw
BRONZE_CONSUMER_GROUP=event-stream-bronze-consumer
DEFAULT_MAX_EVENTS=100
DEFAULT_MAX_SECONDS=60
REQUEST_TIMEOUT_SECONDS=30
HTTP_CONNECT_TIMEOUT_SECONDS=10
HTTP_READ_TIMEOUT_SECONDS=30
STREAM_RECONNECT_SECONDS=2
KAFKA_POLL_TIMEOUT_MS=1000
KAFKA_TOPIC_PARTITIONS=1
KAFKA_TOPIC_REPLICATION_FACTOR=1
BRONZE_RAW_DIR=data/bronze/raw
BRONZE_METADATA_DIR=data/bronze/metadata
BRONZE_STATE_DIR=data/bronze/state
SILVER_TABLES_DIR=data/silver/tables
SILVER_METADATA_DIR=data/silver/metadata
SILVER_STATE_DIR=data/silver/state
GOLD_TABLES_DIR=data/gold/tables
GOLD_METADATA_DIR=data/gold/metadata
GOLD_STATE_DIR=data/gold/state
